# ── Langfuse Observability & Prompt Management ────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Label used to select the active prompt version in Langfuse Prompt Management.
# Admin publishes a new version with the same label (e.g. "production") in the
# Langfuse UI — the app picks it up within 60 seconds. Zero code changes needed.
PROMPT_LABEL=production

# Name of the "classify-input" prompt as it appears in Langfuse Prompt Management.
# Admin can rename the prompt in Langfuse to anything; update only this env var.
# No code changes required to rename or swap the prompt.
CLASSIFY_INPUT_PROMPT=classify-input

# How long (seconds) the app caches a fetched prompt before re-checking Langfuse.
# After creating a new version in Langfuse, the app picks it up within this window.
# Lower = faster propagation of edits;  Higher = fewer Langfuse API calls.
# Default: 60. Use 5 during development/testing, 300 in production.
PROMPT_CACHE_TTL_SECONDS=60

# ── LLM Provider ──────────────────────────────────────────────────────────────
# "azure"  → AzureChatOpenAI  (default, uses keys below)
# "openai" → ChatOpenAI       (uses DEV_OPENAI_API_KEY)
LLM_PROVIDER=azure

OPENAI_API_KEY=
OPENAI_API_BASE=
OPENAI_API_VERSION=
CHAT_DEPLOYMENT=

DEV_OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
PORT=8000
LOGS_NAMPESPACE=jarvis-ai

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
